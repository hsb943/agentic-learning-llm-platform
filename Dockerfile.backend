FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY learning_backend/requirements.txt /tmp/requirements.txt

RUN pip install --upgrade pip \
    && pip install -r /tmp/requirements.txt

COPY learning_backend /app/learning_backend

EXPOSE 8000

CMD ["uvicorn", "learning_backend.api:app", "--host", "0.0.0.0", "--port", "8000"]

